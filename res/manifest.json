{
    "manifest_version": 3,
    "name": "manga-ocr-for-chrome",
    "version": "1.0",
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "permissions": [
        "tabs",
        "activeTab", 
        "scripting",
        "tabCapture",
        "offscreen",
        "storage",
        "contextMenus",
        "commands"
    ],
    "host_permissions": [
        "https://api-free.deepl.com/*",
        "https://api.deepl.com/*",
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "service-worker.js"
    },
    "content_scripts": [{
        "matches": ["<all_urls>"],
        "js": ["content-script.js"],
        "css": ["style.css"],
        "run_at": "document_end"
    }],
    "commands": {
        "activate-capture": {
            "suggested_key": {
                "default": "Alt+C"
            },
            "description": "Start OCR capture"
        }
    },
    "web_accessible_resources": [{
        "resources": [
            "*.wasm",
            "*.mjs",
            "vocab.txt",
            "sample.csv",
            "encoder_model.onnx",
            "decoder_model.onnx"
        ],
        "matches": ["<all_urls>"]
    }],
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; script-src-elem 'self' blob:"
    }
}